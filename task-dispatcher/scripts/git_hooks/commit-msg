#!/bin/bash
# Git commit-msg hook: 验证 commit message 包含 Task ID
# 安装: scripts/install_git_hooks.sh
# 来源: T-20260401-007

set -euo pipefail

MSG=$(cat "$1")

# 环境变量绕过
if [ "${SKIP_TASK_ID_CHECK:-}" = "1" ]; then
    exit 0
fi

# 豁免: Git 自动生成的 commit message
if echo "$MSG" | head -1 | grep -qE "^(Merge |Revert |Initial commit$)"; then
    exit 0
fi

# 校验: 至少包含一个 Task ID (T-YYYYMMDD-NNN)
if echo "$MSG" | grep -qE "T-[0-9]{8}-[0-9]{1,3}"; then
    exit 0
fi

# 校验失败
echo ""
echo "❌ Commit message 必须包含 Task ID"
echo "   格式: type(T-YYYYMMDD-NNN): 描述"
echo "   示例: feat(T-20260401-007): add commit-msg hook"
echo ""
echo "   豁免: Merge/Revert commit 自动跳过"
echo "   绕过: git commit --no-verify（仅限紧急情况）"
echo ""
exit 1
